[Unit]
Description=SAQ Morse Decoder Web Service
After=network.target

[Service]
Type=simple
User=saq
Group=saq
WorkingDirectory=/opt/saq-morse-decoder
Environment=SAQ_VENDOR_DIR=/opt/saq-morse-decoder/vendor
Environment=SAQ_HOST=127.0.0.1
Environment=SAQ_PORT=8080
# Environment=SAQ_API_KEY=geheim
ExecStart=/opt/saq-morse-decoder/.venv/bin/saq-serve
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
